{
  "name": "automation-core",
  "version": "0.1.0",
  "private": true,
  "description": "Local Gmail + Calendar + Notion automation bridge for Codex-driven CRM workflows.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
